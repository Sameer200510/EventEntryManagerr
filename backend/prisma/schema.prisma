// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ENTRY_VOLUNTEER
  FOOD_VOLUNTEER
}

enum ScanType {
  ENTRY
  FOOD
}

enum ScanResult {
  SUCCESS
  DENIED
}

enum ProviderType {
  RESEND
  GOOGLE
  AWS_SES
  SMTP
}

model User {
  id           Int       @id @default(autoincrement())
  name         String    @unique // using name for username/name as it maps from previous user.username
  email        String?   @unique
  passwordHash String
  role         Role      @default(ENTRY_VOLUNTEER)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  scanLogs       ScanLog[]
  auditLogs      AuditLog[]
  uploadDatasets UploadDataset[]
  checkpointStatuses CheckpointStatus[]
}

model Attendee {
  id             Int       @id @default(autoincrement())
  datasetId      Int?
  name           String
  roll           String
  email          String?   
  token          String    @unique
  qrLink         String
  
  entryStatus    Boolean   @default(false)
  foodStatus     Boolean   @default(false)
  
  entryScannedAt DateTime?
  foodScannedAt  DateTime?
  
  entryOtpUsed   Boolean   @default(false)
  foodOtpUsed    Boolean   @default(false)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  dataset        UploadDataset? @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  scanLogs       ScanLog[]
  otpLogs        OtpLog[]
  emailJobs      EmailJob[]
  eventId        Int?
  event          Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkpointStatuses CheckpointStatus[]

  @@unique([datasetId, roll])
}

model UploadDataset {
  id              Int        @id @default(autoincrement())
  eventName       String
  totalRecords    Int
  validRecords    Int
  duplicateEmails Int        @default(0)
  invalidEmails   Int        @default(0)
  isActive        Boolean    @default(false)
  uploadedById    Int?
  eventId         Int?
  createdAt       DateTime   @default(now())

  uploadedBy      User?      @relation(fields: [uploadedById], references: [id])
  event           Event?     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendees       Attendee[]
}

model ScanLog {
  id           Int       @id @default(autoincrement())
  attendeeId   Int?
  scannedById  Int?
  scanType     ScanType?
  checkpointId Int?
  result       ScanResult
  reason       String
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  eventId      Int?

  attendee     Attendee? @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  scannedBy    User?     @relation(fields: [scannedById], references: [id])
  event        Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkpoint   Checkpoint? @relation(fields: [checkpointId], references: [id], onDelete: SetNull)
}

model OtpLog {
  id           Int       @id @default(autoincrement())
  attendeeId   Int
  otpCode      String
  otpType      ScanType
  attempts     Int       @default(0)
  used         Boolean   @default(false)
  expiresAt    DateTime
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())

  attendee     Attendee  @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
}

model EmailProvider {
  id          Int          @id @default(autoincrement())
  name        ProviderType
  isActive    Boolean      @default(false)
  credentials String       // Encrypted JSON
  senderEmail String
  updatedAt   DateTime     @updatedAt
}

model AuditLog {
  id          Int       @id @default(autoincrement())
  adminId     Int?
  action      String
  details     String
  createdAt   DateTime  @default(now())

  admin       User?     @relation(fields: [adminId], references: [id])
}

enum CampaignStatus {
  PENDING
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

enum JobStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  PERM_FAILED
  CANCELLED
}

model EmailCampaign {
  id           Int       @id @default(autoincrement())
  name         String
  status       CampaignStatus @default(PENDING)
  totalCount   Int       @default(0)
  sentCount    Int       @default(0)
  failedCount  Int       @default(0)
  pendingCount Int       @default(0)
  openedCount  Int       @default(0)
  bouncedCount Int       @default(0)
  deliveredCount Int     @default(0)
  batchSize    Int       @default(50)
  delayMs      Int       @default(10000)
  providerName ProviderType?
  eventId      Int?
  templateId   Int?
  scheduledAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  event        Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  jobs         EmailJob[]
}

model EmailJob {
  id            Int       @id @default(autoincrement())
  campaignId    Int
  attendeeId    Int
  status        JobStatus @default(PENDING)
  retries       Int       @default(0)
  maxRetries    Int       @default(3)
  errorMessage  String?
  trackingId    String?   @unique @default(uuid())
  openedAt      DateTime?
  bouncedAt     DateTime?
  deliveredAt   DateTime?
  nextRetryAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign      EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  attendee      Attendee      @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
}

model Event {
  id            Int      @id @default(autoincrement())
  name          String
  type          String   
  date          DateTime
  venue         String?
  bannerImage   String?  // Base64 or URL
  description   String?
  entryTiming   String?  
  exitTiming    String?  
  isActive      Boolean  @default(false)
  isSequential  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  datasets      UploadDataset[]
  campaigns     EmailCampaign[]
  scanLogs      ScanLog[]
  attendees     Attendee[]
  templates     EmailTemplate[]
  checkpoints   Checkpoint[]
}

model EmailTemplate {
  id          Int      @id @default(autoincrement())
  eventId     Int
  name        String
  subject     String
  htmlBody    String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  campaigns   EmailCampaign[]
}

model Checkpoint {
  id        Int      @id @default(autoincrement())
  eventId   Int
  name      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  statuses  CheckpointStatus[]
  scanLogs  ScanLog[]
}

model CheckpointStatus {
  id           Int      @id @default(autoincrement())
  attendeeId   Int
  checkpointId Int
  status       Boolean  @default(false)
  scannedAt    DateTime?
  scannedById  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendee     Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  checkpoint   Checkpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)
  scannedBy    User?    @relation(fields: [scannedById], references: [id])
  
  @@unique([attendeeId, checkpointId])
}
